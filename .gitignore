# Built SPA (produced by `pnpm build`; embedded at image build time).
# Keep the directory (via .gitkeep) so `//go:embed all:dist` compiles.
web/dist/*
!web/dist/.gitkeep
web/node_modules/
web/styled-system/
*.db
*.db-shm
*.db-wal

# `just run` writes both: the dev library root, and the dev data volume
# (SQLite, cover cache, uploads, import staging).
/library-dev/
/data-dev/

# Agent worktrees are checkouts of this repo. Committing one would nest a git
# repo inside the repo it came from.
/.claude/worktrees/
